<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>pepe studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #1a1a1a;
      --sidebar: #2a2a2a;
      --text: #e8e4dc;
      --muted: #888;
      --nav-bg: #111;
      --nav-h: 56px;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      overflow: hidden;
    }

    /* Barre de navigation */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--nav-h);
      background: var(--nav-bg);
      display: flex;
      align-items: stretch;
      justify-content: space-between;
      padding-right: 32px;
      z-index: 100;
      border-bottom: 1px solid #2e2e2e;
    }

    /* Logo */
    .logo-wrap {
      width: 160px;
      height: 56px;
      background: #fff;
      overflow: hidden;
      flex-shrink: 0;
      position: relative;
    }

    .logo-wrap img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      display: block;
    }

    /* Liens de navigation */
    .nav-links {
      display: flex;
      align-items: center;
      gap: 12px;
      list-style: none;
    }

    .nav-links a {
      display: inline-block;
      color: var(--text);
      text-decoration: none;
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: lowercase;
      padding: 7px 20px;
      border: 1px solid transparent;
      transition: border-color 0.2s, background 0.2s, color 0.2s;
    }

    .nav-links a:hover {
      border-color: var(--text);
    }

    .nav-links a.active {
      border-color: var(--text);
      background: var(--text);
      color: #111;
    }

    /* Layout */
    .page {
      display: flex;
      height: 100vh;
      padding-top: var(--nav-h);
    }

    /* Barre latérale */
    .sidebar {
      width: 160px;
      flex-shrink: 0;
      background: var(--sidebar);
      border-right: 1px solid #333;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 36px;
      padding: 0 24px;
    }

    .sidebar a {
      color: var(--text);
      text-decoration: none;
      font-size: 14px;
      letter-spacing: 0.04em;
      text-transform: lowercase;
      opacity: 0.7;
      transition: opacity 0.2s, transform 0.2s;
      display: block;
      padding: 8px 0;
    }

    .sidebar a:hover {
      opacity: 1;
      transform: translateX(4px);
    }

    .sidebar a.active {
      opacity: 1;
    }

    /* Contenu principal */
    main {
      flex: 1;
      display: flex;
      flex-wrap: wrap;
      padding: 20px;
      gap: 20px;
      overflow-y: auto;
    }

    /* Grille de produits */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      flex: 1;
      padding: 20px;
    }

    .product-item {
      position: relative;
      aspect-ratio: 1;
      overflow: hidden;
      border: 1px solid #333;
    }

    .product-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Adaptation pour mobile */
    @media (max-width: 700px) {
      .sidebar {
        display: none;
      }

      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</head>
<body>
  <nav>
    <div class="logo-wrap">
      <img src="logo.webp" alt="Logo" />
    </div>
    <ul class="nav-links">
      <li><a href="#" class="active">présentation</a></li>
      <li><a href="#">contact</a></li>
      <li><a href="#">panier</a></li>
    </ul>
  </nav>

  <div class="page">
    <aside class="sidebar">
      <a href="#" class="active">best sellers</a>
      <a href="#">homme</a>
      <a href="#">femme</a>
    </aside>

    <main>
      <div class="product-grid">
        <div class="product-item">
          <img src="produit1.jpg" alt="Produit 1" />
        </div>
        <div class="product-item">
          <img src="produit2.jpg" alt="Produit 2" />
        </div>
        <div class="product-item">
          <img src="produit3.jpg" alt="Produit 3" />
        </div>
        <div class="product-item">
          <img src="produit4.jpg" alt="Produit 4" />
        </div>
        <div class="product-item">
          <img src="produit5.jpg" alt="Produit 5" />
        </div>
        <div class="product-item">
          <img src="produit6.jpg" alt="Produit 6" />
        </div>
        <div class="product-item">
          <img src="produit7.jpg" alt="Produit 7" />
        </div>
        <div class="product-item">
          <img src="produit8.jpg" alt="Produit 8" />
        </div>
      </div>
    </main>
  </div>
</body>
</html>